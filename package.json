{
  "name": "formstack",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check-types": "turbo run check-types",
    "db:push": "pnpm --filter @formstack/db db:push",
    "db:migrate": "pnpm --filter @formstack/db db:migrate",
    "db:seed": "pnpm --filter @formstack/db db:seed",
    "db:studio": "pnpm --filter @formstack/db db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
