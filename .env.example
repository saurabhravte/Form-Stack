# --- Database ---
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/<projectName>"

# --- Auth ---
JWT_SECRET="please-change-me-in-production-this-must-be-at-least-32-chars"
JWT_EXPIRES_IN="7d"
COOKIE_DOMAIN="localhost"

# --- URLs ---
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Server ---
PORT=4000
NODE_ENV="development"

# --- Email (optional, stubbed if missing) ---
RESEND_API_KEY=""
EMAIL_FROM="FormStack <no-reply@formstack.dev>"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
