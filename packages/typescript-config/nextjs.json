{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": ["src", "next-env.d.ts", "next.config.js", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next"]
}
